services:
  app:
    build: .
    container_name: {{ project_name }}-app
    restart: unless-stopped
    env_file: .env
    ports:
      - "{{ app_port }}:{{ app_port }}"
    volumes:
      - ./:/app
      - app_node_modules:/app/node_modules
      - app_svelte_kit:/app/.svelte-kit

volumes:
  app_node_modules:
  app_svelte_kit:
