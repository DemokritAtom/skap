# Database connection (SQLAlchemy / asyncpg URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/{{ project_name_snake }}

# Used for signing JWTs / cookies. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-real-secret

# Toggles uvicorn auto-reload + verbose tracebacks.
DEBUG=true
